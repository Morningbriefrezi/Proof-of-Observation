# Privy — get from privy.io dashboard (required, app will throw if missing)
NEXT_PUBLIC_PRIVY_APP_ID=
# Anthropic Claude API
ANTHROPIC_API_KEY=
# Database (Neon — get from console.neon.tech)
DATABASE_URL=
# Solana RPC (devnet)
SOLANA_RPC_URL=https://api.devnet.solana.com
# Fee payer (devnet)
FEE_PAYER_PRIVATE_KEY=
# SPL Token mint address for STARS token (Solana devnet)
STARS_TOKEN_MINT=
# Merkle tree address for compressed NFTs
MERKLE_TREE_ADDRESS=
# Collection mint address for cNFTs
COLLECTION_MINT_ADDRESS=
# Internal API secret for server-to-server routes (award-stars, mint)
INTERNAL_API_SECRET=
